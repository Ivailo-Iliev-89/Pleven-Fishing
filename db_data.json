{
  "model": "fishing_app.method",
  "pk": 1,
  "fields": {
    "name": "Feeder Fishing",
    "slug": "feeder-fishing",
    "description": "Feeder fishing is not just about lazily casting a feeder and waiting for something to happen, as most anglers think. Feeder fishing is a very successful method that catches a lot of fish and also allows you to fish in areas inaccessible to other methods.\r\nAccuracy is the most important thing you need to achieve when fishing with a feeder. You need to be accurate at all times and cast the feeder in a small radius even at a long distance.",
    "image": ""
  }
},
{
